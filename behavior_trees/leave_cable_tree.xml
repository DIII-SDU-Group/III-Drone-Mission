<root BTCPP_format="4" main_tree_to_execute="LeaveCable">
     <BehaviorTree ID="LeaveCable">
        <Sequence name="leave_cable_top_sequence">
           <Action 
                ID="LogMessage" 
                name="log"
                message="Leave cable tree started. Hovering on cable."
                log_level="2"
            />

            <Action ID="HoverOnCable" name="hover_on_cable" 
                  target_cable_id="{@target_cable_id}"
                  duration_s="3." 
                  sustain_action="true"
                  target_upwards_velocity="2.0"
            />

            <!-- <Action ID="HoverOnCable" name="hover_on_cable_2" 
                target_cable_id="{@target_cable_id}"
                duration_s="10." 
                target_upwards_velocity="2.0"
                stop_maneuver_after_timeout_ms="9900"
            />

           <Action 
                ID="LogMessage" 
                name="log"
                message="Hovering on cable completed."
                log_level="2"
            />

            <Action 
                  ID="GripperCommand" 
                  name="gripper_command_open" 
                  gripper_command="0" 
            /> -->

            <Action 
                ID="PLMapperCommand" 
                name="pl_mapper_command_pause" 
                pl_mapper_command="2" 
                reset="false"
            />

            <Action
               ID="CableTakeoff"
               name="cable_takeoff"
               target_cable_id="{@target_cable_id}"
            />

            <Action 
                ID="PLMapperCommand" 
                name="pl_mapper_command_stop" 
                pl_mapper_command="1" 
                reset="true"
            />

            <SubTree 
                ID="FlyToInitPosition"
                initial_state="{@initial_state}"
                initial_yaw="{@initial_yaw}"
                waypoints="{@waypoints_return}"
            />
            
        </Sequence>
     </BehaviorTree>

     <BehaviorTree ID="FlyToInitPosition">
        <Sequence name="fly_to_init_position_sequence">
            <Action
                ID="PublishPowerlineWaypoints"
                name="publish_powerline_waypoints"
                waypoints="{waypoints}"
                target_yaw="{initial_yaw}"
            />

            <LoopPoint queue="{waypoints}" value="{waypoint}">
                <Decorator ID="Delay" name="delay_between_waypoints" delay_msec="100">
                    <Action
                        ID="FlyToPosition"
                        name="fly_to_position"
                        target_position="{waypoint}"
                        target_yaw="{initial_yaw}"
                        frame_id="world"
                    />
                </Decorator>
            </LoopPoint>
        </Sequence>
     </BehaviorTree>

 </root>
