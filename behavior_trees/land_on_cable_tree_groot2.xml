<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="LandOnCable">
  <BehaviorTree ID="LandOnCable">
    <Sequence name="land_on_cable_top_sequence">
      <RetryUntilSuccessful name="store_init_state_retry_until_successful"
                            num_attempts="3">
        <Delay name="delay_store_state"
               delay_msec="1000">
          <StoreCurrentState name="store_initial_state"
                             current_yaw="{@initial_yaw}"
                             current_position="{@initial_position}"
                             current_state="{@initial_state}"/>
        </Delay>
      </RetryUntilSuccessful>
      <Sequence name="fly_to_under_cable_sequence">
        <GetPowerlineOverview name="get_powerline_overview"
                              stored_powerline="{stored_powerline}"/>
        <PowerlineWaypointProvider name="fly_to_powerline_waypoint_provider"
                                   waypoints_return="{@waypoints_return}"
                                   start_state="{@initial_state}"
                                   waypoints_depart="{waypoints}"
                                   stored_powerline="{stored_powerline}"/>
        <LoopPoint value="{waypoint}"
                   queue="{waypoints}">
          <Delay name="delay_between_waypoints"
                 delay_msec="1000">
            <FlyToPosition name="fly_to_position"
                           target_yaw="{@initial_yaw}"
                           frame_id="world"
                           target_position="{waypoint}"/>
          </Delay>
        </LoopPoint>
      </Sequence>
      <Sequence name="retry_land_on_cable_sequence">
        <StoreCurrentState name="store_start_state"
                           current_yaw="{start_yaw}"
                           current_position="{start_position}"
                           current_state="{start_state}"/>
        <RetryUntilSuccessful name="full_sequence_retry_until_successful"
                              num_attempts="3">
          <Fallback name="land_on_cable_or_fly_back_to_init_fallback">
            <Sequence name="land_on_cable_core_sequence">
              <PLMapperCommand name="pl_mapper_command_start"
                               pl_mapper_command="start"/>
              <Hover name="hover_while_waiting_for_powerline"
                     duration_s="10."/>
              <RetryUntilSuccessful name="detect_powerline_retry_until_successful"
                                    num_attempts="9">
                <Delay name="delay_while_waiting_for_powerline"
                       delay_msec="1000">
                  <VerifyPowerlineDetected name="verify_powerline_detected"
                                           required_n_lines="2"/>
                </Delay>
              </RetryUntilSuccessful>
              <SelectTargetLine name="select_target_line"
                                target_cable_id="{@target_cable_id}"/>
              <TargetProvider name="fly_to_cable_target_provider"
                              target="{fly_to_cable_target}"
                              target_id="{@target_cable_id}"
                              mode="fly_to_cable"/>
              <FlyToObject name="fly_to_cable"
                           target="{fly_to_cable_target}"/>
              <TargetProvider name="hover_by_cable_target_provider"
                              target="{hover_by_cable_target}"
                              target_id="{@target_cable_id}"
                              mode="hover_by_cable"/>
              <HoverByObject name="hover_by_cable"
                             duration_s="10."
                             target="{hover_by_cable_target}"/>
              <PLMapperCommand name="pl_mapper_command_pause"
                               pl_mapper_command="pause"/>
              <GripperCommand name="gripper_command_close"
                              gripper_command="close"/>
              <RetryUntilSuccessful name="landing_maneuver_retry_until_successful"
                                    num_attempts="3">
                <Fallback name="landing_maneuver_fallback">
                  <CableLanding name="cable_landing"
                                target_cable_id="{@target_cable_id}"/>
                  <ForceFailure name="fly_back_down_under_cable_force_failure">
                    <Delay name="delay_fly_back_down_under_cable"
                           delay_msec="1000">
                      <FlyToObject name="fly_back_down_under_cable"
                                   target="{fly_to_cable_target}"/>
                    </Delay>
                  </ForceFailure>
                </Fallback>
              </RetryUntilSuccessful>
              <HoverOnCable name="hover_on_cable"
                            target_cable_id="{@target_cable_id}"
                            duration_s="10."/>
              <RetryUntilSuccessful name="gripper_closed_retry"
                                    num_attempts="5">
                <Delay name="delay_gripper_closed"
                       delay_msec="1000">
                  <VerifyGripperClosed name="verify_gripper_closed"/>
                </Delay>
              </RetryUntilSuccessful>
              <PLMapperCommand name="pl_mapper_command_freeze"
                               pl_mapper_command="freeze"/>
            </Sequence>
            <Sequence name="fly_back_to_init_sequence">
              <PLMapperCommand name="pl_mapper_command_stop"
                               pl_mapper_command="stop"/>
              <GripperCommand name="gripper_command_open"
                              gripper_command="open"/>
              <ForceFailure name="fly_back_to_start_force_failure">
                <FlyToPosition name="fly_to_position"
                               target_yaw="{start_yaw}"
                               frame_id="world"
                               target_position="{start_position}"/>
              </ForceFailure>
            </Sequence>
          </Fallback>
        </RetryUntilSuccessful>
      </Sequence>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="CableLanding">
      <input_port name="target_cable_id"
                  type="int"/>
    </Action>
    <Action ID="FlyToObject">
      <input_port name="target"
                  type="iii_drone_interfaces::msg::Target_&lt;std::allocator&lt;void&gt; &gt;"/>
    </Action>
    <Action ID="FlyToPosition">
      <input_port name="target_yaw"
                  type="float"/>
      <input_port name="frame_id"
                  type="std::string"/>
      <input_port name="target_position"
                  type="Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt;"/>
    </Action>
    <Action ID="GetPowerlineOverview">
      <output_port name="stored_powerline"
                   type="iii_drone_interfaces::msg::Powerline_&lt;std::allocator&lt;void&gt; &gt;"/>
    </Action>
    <Action ID="GripperCommand">
      <input_port name="gripper_command"
                  type="iii_drone::behavior::gripper_command_t"/>
    </Action>
    <Action ID="Hover">
      <input_port name="duration_s"
                  default="1.000000"
                  type="float">Duration of the hover maneuver in seconds</input_port>
    </Action>
    <Action ID="HoverByObject">
      <input_port name="duration_s"
                  default="1.000000"
                  type="float">Duration of the hover maneuver in seconds</input_port>
      <input_port name="target"
                  type="iii_drone_interfaces::msg::Target_&lt;std::allocator&lt;void&gt; &gt;">Target to hover by</input_port>
    </Action>
    <Action ID="HoverOnCable">
      <input_port name="target_cable_id"
                  type="int">The target cable ID</input_port>
      <input_port name="duration_s"
                  default="1.000000"
                  type="float">Duration of the hover maneuver in seconds</input_port>
    </Action>
    <Decorator ID="LoopPoint">
      <output_port name="value"
                   type="Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt;"/>
      <inout_port name="queue"
                  type="std::shared_ptr&lt;std::deque&lt;Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt;, std::allocator&lt;Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt; &gt; &gt; &gt;"/>
    </Decorator>
    <Action ID="PLMapperCommand">
      <input_port name="pl_mapper_command"
                  type="iii_drone::behavior::pl_mapper_command_t"/>
    </Action>
    <Action ID="PowerlineWaypointProvider">
      <output_port name="waypoints_return"
                   type="std::shared_ptr&lt;std::deque&lt;Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt;, std::allocator&lt;Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt; &gt; &gt; &gt;"/>
      <input_port name="start_state"
                  type="iii_drone::control::State"/>
      <output_port name="waypoints_depart"
                   type="std::shared_ptr&lt;std::deque&lt;Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt;, std::allocator&lt;Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt; &gt; &gt; &gt;"/>
      <input_port name="stored_powerline"
                  type="iii_drone_interfaces::msg::Powerline_&lt;std::allocator&lt;void&gt; &gt;"/>
    </Action>
    <Condition ID="SelectTargetLine">
      <output_port name="target_cable_id"
                   type="int"/>
    </Condition>
    <Condition ID="StoreCurrentState">
      <output_port name="current_yaw"
                   type="float">Current yaw</output_port>
      <output_port name="current_position"
                   type="Eigen::Matrix&lt;float, 3, 1, 0, 3, 1&gt;">Current position</output_port>
      <output_port name="current_state"
                   type="iii_drone::control::State">Current state</output_port>
    </Condition>
    <Condition ID="TargetProvider">
      <output_port name="target"
                   type="iii_drone_interfaces::msg::Target_&lt;std::allocator&lt;void&gt; &gt;">Provided target</output_port>
      <input_port name="target_id"
                  type="int">Id of the target</input_port>
      <input_port name="mode"
                  type="iii_drone::behavior::target_provider_mode_t">Mode of the target provider</input_port>
    </Condition>
    <Condition ID="VerifyGripperClosed"/>
    <Condition ID="VerifyPowerlineDetected">
      <input_port name="required_n_lines"
                  type="unsigned int"/>
    </Condition>
  </TreeNodesModel>

</root>
