            <Action 
                ID="Sleep" 
                name="sleep" 
                msec="5000"
            />

            <Action 
                ID="ModeExecutorScheduleRequest" 
                name="takeoff_request" 
                schedule_request_type="1"
                takeoff_altitude="4"
            />

        </Sequence>
     </BehaviorTree>

 </root>
