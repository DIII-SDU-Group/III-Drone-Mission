<root BTCPP_format="4" main_tree_to_execute="Takeoff">
     <BehaviorTree ID="Takeoff">
        <Sequence name="takeoff_sequence">

            <Action 
                ID="LogMessage" 
                name="log"
                message="Takeoff behavior tree started. Sleeping."
                log_level="1"
            />

            <Action 
                ID="Sleep" 
                name="sleep" 
                msec="5000"
            />

            <Action 
                ID="LogMessage" 
                name="log"
                message="Sleep finished. Issuing takeoff command."
                log_level="1"
            />

            <Action 
                ID="ModeExecutorAction" 
                name="takeoff" 
                action_request_type="1"
                takeoff_altitude="4"
            />

        </Sequence>
     </BehaviorTree>

 </root>
